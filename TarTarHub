task.spawn(function()
    while true do
        local hue = tick() % 5 / 5
        MainGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromHSV(hue, 1, 1)),
            ColorSequenceKeypoint.new(0.5, Color3.fromHSV((hue + 0.25) % 1, 1, 1)),
            ColorSequenceKeypoint.new(1, Color3.fromHSV((hue + 0.5) % 1, 1, 1))
        })
        MainStroke.Color = Color3.fromHSV(hue, 0.8, 1)
        RunService.RenderStepped:Wait()
    end
end)

-- Movement
local isRunning = false
local waypoints = {Vector3.new(-79.18, 145.41, -81.43), Vector3.new(-12.04, 146.96, -80.25)}

ToggleBtn.MouseButton1Click:Connect(function()
    isRunning = not isRunning
    ToggleBtn.Text = isRunning and "ON" or "OFF"
    ToggleBtn.BackgroundColor3 = isRunning and Color3.fromRGB(80, 20, 150) or Color3.fromRGB(40, 40, 40)
    StatusLabel.Text = isRunning and "STATUS: doing job" or "STATUS: chilling"
end)

task.spawn(function()
    while true do
        if isRunning then
            local char = player.Character or player.CharacterAdded:Wait()
            local root = char:WaitForChild("HumanoidRootPart")
            for _, wp in ipairs(waypoints) do
                if not isRunning then break end
                local speed = tonumber(SpeedInput.Text) or 250
                local dist = (root.Position - wp).Magnitude
                local t = TweenService:Create(root, TweenInfo.new(dist/speed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(wp)})
                t:Play()
                t.Completed:Wait()
                task.wait(0.1)
            end
        end
        task.wait(0.1)
    end
end)

