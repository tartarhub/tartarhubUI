-- --- NOTIFICATION SYSTEM ---
local function Notify(title, text)
    task.spawn(function()
        pcall(function()
            StarterGui:SetCore("SendNotification", {
                Title = title,
                Text = text,
                Duration = 5,
                Icon = "rbxassetid://6032220199"
            })
        end)
    end)
end

-- --- ADMIN DETECTOR ---
local function CheckForAdmin(p)
    if p == player then return end
    task.spawn(function()
        task.wait(1) 
        local rank = p:GetRoleInGroup(game.CreatorId) or "None"
        local staffKeywords = {"admin", "mod", "staff", "owner", "host", "dev"}
        local isStaff = false
        
        for _, word in ipairs(staffKeywords) do
            if string.find(string.lower(rank), word) then isStaff = true break end
        end
        if p:FindFirstChild("AdminRank") or p:FindFirstChild("HDAdminRank") then isStaff = true end

        if isStaff then
            Notify("⚠️ ADMIN DETECTED", p.Name .. " (" .. rank .. ")")
        end
    end)
end

Players.PlayerAdded:Connect(CheckForAdmin)
for _, p in ipairs(Players:GetPlayers()) do CheckForAdmin(p) end

