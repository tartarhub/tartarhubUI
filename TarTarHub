-- --- LOGIC ---
local function runTeleport()
    local t = CoordInput.Text:split(",")
    if #t < 3 then return end
    local dest = Vector3.new(tonumber(t[1]), tonumber(t[2]), tonumber(t[3]))
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = CFrame.new(dest) end
end

local function toggleMain(state)
    if state == false then
        lastPos = MainFrame.Position
        MainFrame.Visible, SettingsFrame.Visible, MoverFrame.Visible = false, false, false
        NoobContainer.Visible = true
    else
        NoobContainer.Visible = false
        MainFrame.Visible = true
        MainFrame.Position = lastPos
    end
    guiVisible = state
end

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if isListeningMain then mainGuiHotkey = input.KeyCode; GuiHotkeyBtn.Text = "UI: " .. input.KeyCode.Name; isListeningMain = false
    elseif isListeningMover then moverHotkey = input.KeyCode; MHotkeyBtn.Text = "KEY: " .. input.KeyCode.Name; isListeningMover = false
    elseif input.KeyCode == mainGuiHotkey then toggleMain(not guiVisible)
    elseif input.KeyCode == moverHotkey and MoverFrame.Visible then runTeleport() end
end)

