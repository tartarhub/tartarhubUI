-- Movement Loop
task.spawn(function()
    while true do
        if isRunning then
            local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                for _, wp in ipairs(waypoints) do
                    if not isRunning then break end
                    local dist = (hrp.Position - wp).Magnitude
                    local t = TweenService:Create(hrp, TweenInfo.new(dist/movementSpeed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(wp)})
                    t:Play(); t.Completed:Wait()
                end
            end
        end
        task.wait(0.1)
    end
end)
